{
  "compilerOptions": {
    "lib": ["es2021", "dom"],
    "declaration": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "rootDir": "schematics",
    "outDir": "schematics",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2021",
    "types": ["jasmine", "node"]
  },
  "include": ["schematics/**/*.ts"],
  "exclude": ["schematics/**/files/**"]
}
